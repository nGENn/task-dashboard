# General
USE_DOCKER=yes
IPYTHONDIR=/app/.ipython

# Keycloak (dummy values)
KEYCLOAK_CLIENT_ID=dummy
KEYCLOAK_CLIENT_SECRET=dummy
KEYCLOAK_SERVER_URL=https://example.com/realms/example/.well-known/openid-configuration

# Eramba Integration (unused in CI; keep placeholders)
ERAMBA_API_URL=
ERAMBA_API_KEY=dummy

# EspoCRM Integration (service not in CI; keep consistent URL + dummy key)
ESPO_API_URL=http://espocrm:80
ESPO_API_KEY=dummy

# GitLab Integration (service not in CI; keep consistent URL + dummy token)
GITLAB_API_URL=http://gitlab:8004
GITLAB_API_TOKEN=dummy

# OpenProject Integration (service not in CI; keep consistent URL + dummy key)
OPENPROJECT_API_URL=http://openproject:80
OPENPROJECT_API_KEY=dummy
OPENPROJECT_HOST_HEADER=openproject:80

# Zammad Integration (service not in CI; keep consistent URL + dummy token)
ZAMMAD_API_URL=http://zammad-nginx:8080
ZAMMAD_API_TOKEN=dummy