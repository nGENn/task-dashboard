# ==============================================================================
# GENERAL SETTINGS
# ==============================================================================
# Generate a secure key: `openssl rand -base64 32`
DJANGO_SECRET_KEY=unsafe-secret-key-change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,0.0.0.0,127.0.0.1
# Timezone (default: Europe/Berlin)
# TIME_ZONE=UTC

# ==============================================================================
# DATABASE & REDIS
# ==============================================================================
# Format: postgres://user:password@host:port/dbname
DATABASE_URL=postgres://debug:debug@postgres:5432/task_dashboard
REDIS_URL=redis://redis:6379/0

# ==============================================================================
# AUTHENTICATION (OIDC / Keycloak)
# ==============================================================================
# Set to True to enforce Allauth workflow for Admin
DJANGO_ADMIN_FORCE_ALLAUTH=False
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_SERVER_URL=

# ==============================================================================
# EMAIL SETTINGS
# ==============================================================================
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL="Task Dashboard <noreply@tasks.ngenn.net>"
# DJANGO_SERVER_EMAIL=

# ==============================================================================
# PRODUCTION / SECURITY
# ==============================================================================
# Sentry DSN for error tracking
SENTRY_DSN=
DJANGO_SENTRY_LOG_LEVEL=20
SENTRY_ENVIRONMENT=production

# Security settings (defaults are usually safe for prod)
# DJANGO_SECURE_SSL_REDIRECT=True
# DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True

# ==============================================================================
# INTEGRATIONS
# ==============================================================================
# Eramba: How many days into the future to consider "Open" tasks relevant (default: 30)
ERAMBA_OPEN_TASK_FUTURE_WINDOW_DAYS=30
