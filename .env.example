# ==============================================================================
# GENERAL SETTINGS
# ==============================================================================
# WARNING: This key also encrypts all stored API tokens and passwords via
# EncryptedCharField. Changing it will permanently lock out all stored service
# credentials. Keep it stable and back it up.
# Generate: python -c "from django.utils.crypto import get_random_string; print(get_random_string(50))"
DJANGO_SECRET_KEY=unsafe-secret-key-change-me-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=task.ngenn.net,localhost,127.0.0.1
# Obfuscated Admin URL (default: explicit-declared-follow/)
DJANGO_ADMIN_URL=explicit-declared-follow/

# ==============================================================================
# DATABASE & INFRASTRUCTURE
# ==============================================================================
# Format: postgres://user:password@host:port/dbname
DATABASE_URL=postgres://postgres:postgres@postgres:5432/task_dashboard
# Note: Use 'redis://' scheme even for Valkey for technical compatibility
VALKEY_URL=redis://valkey:6379/0

# ==============================================================================
# AUTHENTICATION (OIDC / Keycloak / SSO)
# ==============================================================================
# Provider configuration for django-allauth
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
# Base realm URL (e.g., https://id.example.com/realms/myrealm)
KEYCLOAK_SERVER_URL=

# ==============================================================================
# PERMISSIONS & ROLES
# ==============================================================================
# Set to True to enforce Allauth workflow for Django Admin access
DJANGO_ADMIN_FORCE_ALLAUTH=True

# ==============================================================================
# EMAIL SETTINGS
# ==============================================================================
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL="Task Dashboard <noreply@yourdomain.com>"

# ==============================================================================
# SECURITY & MONITORING
# ==============================================================================
# Error tracking via Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# Strict Security Headers (Ensure SSL is handled by reverse proxy like Traefik/Nginx)
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True

# ==============================================================================
# INTEGRATIONS (Global Defaults)
# ==============================================================================
# These are fallback keys used if not configured via the Dashbaord UI.
# It is recommended to configure these in the Admin Panel instead.

ZAMMAD_API_URL=
ZAMMAD_API_TOKEN=

GITLAB_API_URL=
GITLAB_API_TOKEN=

ESPO_API_URL=
ESPO_API_KEY=

OPENPROJECT_API_URL=
OPENPROJECT_API_KEY=

# Eramba Logic: How many days into the future to consider "Open" tasks relevant (default: 30)
ERAMBA_OPEN_TASK_FUTURE_WINDOW_DAYS=30
