{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Manage",
            "type": "shell",
            "command": "uv run ./manage.py ${input:manageArgs}",
            "group": "none",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Start Server",
            "type": "shell",
            "command": "uv run ./manage.py runserver_plus",
            "group": "none",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Pre-commit (Staged)",
            "type": "shell",
            "command": "uv run pre-commit run --show-diff-on-failure --color=always",
            "group": "test",
            "presentation": {
                "reveal": "silent",
                "panel": "new",
                "clear": true
            }
        },
        {
            "label": "Pre-commit (All Files)",
            "type": "shell",
            "command": "uv run pre-commit run --all-files --show-diff-on-failure --color=always",
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "clear": true
            }
        },
        {
            "label": "Run Tests",
            "type": "shell",
            "command": "uv run pytest",
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "clear": true,
                "showReuseMessage": false
            },
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "manageArgs",
            "type": "promptString",
            "description": "Enter django management command (e.g. migrate)",
            "default": "migrate"
        }
    ]
}
