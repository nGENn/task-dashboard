{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Manage",
            "type": "shell",
            "command": "uv run ./manage.py ${input:manageArgs}",
            "group": "none",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Start Server",
            "type": "shell",
            "command": "uv run ./manage.py runserver_plus",
            "group": "none",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Start Server (Debug)",
            "type": "shell",
            "command": "DJANGO_SETTINGS_MODULE=config.settings.debug uv run ./manage.py runserver 0.0.0.0:8000",
            "group": "none",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Pre-commit (Staged)",
            "type": "shell",
            "command": "uv run pre-commit run --color=always",
            "group": "test",
            "presentation": {
                "reveal": "silent",
                "panel": "new",
                "clear": true
            }
        },
        {
            "label": "Pre-commit (All Files)",
            "type": "shell",
            "command": "uv run pre-commit run --all-files --color=always",
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "clear": true
            }
        },
        {
            "label": "Start QCluster",
            "type": "shell",
            "command": "uv run manage.py qcluster",
            "group": "none",
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "clear": true,
                "showReuseMessage": false
            },
            "problemMatcher": []
        },
        {
            "label": "DaisyUI Watch",
            "type": "shell",
            "command": "if [ ! -f task_dashboard/static/css/tailwindcss ]; then mkdir -p task_dashboard/static/css && cd task_dashboard/static/css && curl -sL daisyui.com/fast | bash && cd -; fi; ${workspaceFolder}/task_dashboard/static/css/tailwindcss -i ${workspaceFolder}/task_dashboard/static/css/input.css -o ${workspaceFolder}/task_dashboard/static/css/output.css --watch",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            },
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "manageArgs",
            "type": "promptString",
            "description": "Enter django management command (e.g. migrate)",
            "default": "migrate"
        }
    ]
}